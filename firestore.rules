rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    function isSignedIn() {
      return request.auth != null;
    }

    function userDoc() {
      return get(/databases/$(database)/documents/users/$(request.auth.uid));
    }

    function isAdmin() {
      return isSignedIn() && userDoc().data.role == "admin" && userDoc().data.active == true;
    }

    function isActiveUser() {
      return isSignedIn() && userDoc().data.active == true;
    }

    // -------- users --------
    match /users/{uid} {
      // Self read OR admin read.
      allow get: if isSignedIn() && (request.auth.uid == uid || isAdmin());
      // Only admin lists all users.
      allow list: if isAdmin();
      // Only admin creates / updates / deletes user documents.
      allow create, update, delete: if isAdmin();
    }

    // -------- requests --------
    match /requests/{requestId} {
      // Admin sees all, employee only own.
      allow get: if isSignedIn() && (isAdmin() || resource.data.employeeId == request.auth.uid);
      allow list: if isSignedIn();

      // Employee creates a request for themselves, status must start as pending.
      allow create: if isActiveUser()
        && request.resource.data.employeeId == request.auth.uid
        && request.resource.data.status == "pending";

      // Admin can update freely. Employee can only cancel their own pending/preapproved request.
      allow update: if isAdmin()
        || (
          resource.data.employeeId == request.auth.uid
          && request.resource.data.status == "cancelled"
          && resource.data.status in ["pending", "preapproved"]
        );

      // No deletes (audit trail).
      allow delete: if false;

      // history subcollection (kept for future; today history lives in array on parent doc)
      match /history/{eventId} {
        allow read: if isAdmin()
          || get(/databases/$(database)/documents/requests/$(requestId)).data.employeeId == request.auth.uid;
        allow create: if isSignedIn();
        allow update, delete: if false;
      }
    }

    // -------- notifications --------
    match /notifications/{notifId} {
      allow get, list: if isSignedIn() && resource.data.userId == request.auth.uid;
      // Notifications are created server-side or by admin actions through transactions.
      allow create: if isSignedIn();
      // The recipient can flip "read" but nothing else.
      allow update: if isSignedIn()
        && resource.data.userId == request.auth.uid
        && request.resource.data.diff(resource.data).changedKeys().hasOnly(["read"]);
      allow delete: if isAdmin();
    }

    // -------- catalogs (areas, supervisors) --------
    match /areas/{areaId} {
      allow read: if isSignedIn();
      allow create, update, delete: if isAdmin();
    }
    match /supervisors/{supId} {
      allow read: if isSignedIn();
      allow create, update, delete: if isAdmin();
    }

    // -------- counters --------
    match /counters/{counterId} {
      // Any active user can increment the counter when creating a request
      // (transaction-protected on the client side).
      allow read, write: if isActiveUser();
    }
  }
}
